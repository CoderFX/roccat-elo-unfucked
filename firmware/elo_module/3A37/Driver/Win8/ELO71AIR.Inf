;
;Turtle Beach ELO 7.1 AIR Driver
;

[Version]
signature="$WINDOWS NT$"
Class=Media
ClassGUID={4d36e96c-e325-11ce-bfc1-08002be10318}
Provider=%CMEDIA%
Catalogfile=ELO71AIR.cat
DriverVer=08/17/2020,8.0.01.03

[SourceDisksNames]
1000=%cdname%,,,

[SourceDisksFiles.x86]
ELO71AIR.sys=1000,\x86
CMEFFECTAPO_ELO71AIR.dll=1000,\x86
CMCPLEXT_ELO71AIR.dll=1000,\x86

[SourceDisksFiles.amd64]
ELO71AIR.sys=1000,\x64
CMEFFECTAPO_ELO71AIR.dll=1000,\x64
CMCPLEXT_ELO71AIR.dll=1000,\x64

[SignatureAttributes]
ELO71AIR.sys=SignatureAttributes.DRM
CMEFFECTAPO_ELO71AIR.dll=SignatureAttributes.PETrust
CMCPLEXT_ELO71AIR.dll=SignatureAttributes.PETrust

[SignatureAttributes.DRM]
DRMLevel=1300

[SignatureAttributes.PETrust]
PETrust=true

[DestinationDirs]
DefaultDestDir=12
ELO71AIR.CopyFiles=12
CMEFFECTAPO_ELO71AIR.CopyFiles=11

[Manufacturer]
%ManufacturerString%=ManufacturerID,NTamd64

[ManufacturerID]
%ELO71AIR.DeviceDesc%=ELO71AIR,USB\VID_1E7D&PID_3A37&MI_01

[ManufacturerID.NTamd64]
%ELO71AIR.DeviceDesc%=ELO71AIR,USB\VID_1E7D&PID_3A37&MI_01

;---------------------------------------------------------------
;                x 86  D D I n s t a l l
;---------------------------------------------------------------

[ELO71AIR]
Include=ks.inf, wdmaudio.inf
Needs=KS.Registration, WDMAUDIO.Registration,mssysfx.CopyFilesAndRegister
DelReg=ELO71AIR.DelReg
AddReg=ELO71AIR.AddReg, ELO71AIR_NAMES.AddReg, SfxFx.AddReg
AddProperty=ELO71AIRBranding.AddProperty
CopyFiles=ELO71AIR.CopyFiles, CMEFFECTAPO_ELO71AIR.CopyFiles

;---------------------------------------------------------------
;                x 64  D D I n s t a l l
;---------------------------------------------------------------

[ELO71AIR.NTamd64]
Include=ks.inf, wdmaudio.inf
Needs=KS.Registration, WDMAUDIO.Registration,mssysfx.CopyFilesAndRegister
DelReg=ELO71AIR.DelReg
AddReg=ELO71AIR.AddReg, ELO71AIR_NAMES.AddReg, SfxFx.AddReg
AddProperty=ELO71AIRBranding.AddProperty
CopyFiles=ELO71AIR.CopyFiles, CMEFFECTAPO_ELO71AIR.CopyFiles

[ELO71AIRBranding.AddProperty]
DeviceVendorWebSite,,,,"https://www.turtlebeach.com/pages/elite-atlas-aero-headset" ; Place your URL here

;---------------------------------------------------------------
;                I n t e r f a c e s
;---------------------------------------------------------------

[ELO71AIR.Interfaces]
AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_SPEAKER.WAVE%,Audio.I.SPEAKER.WAVE
AddInterface=%KSCATEGORY_RENDER%,%KSNAME_SPEAKER.WAVE%,Audio.I.SPEAKER.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_SPDIFOUT.WAVE%,Audio.I.SPDIFOUT.WAVE
AddInterface=%KSCATEGORY_RENDER%,%KSNAME_SPDIFOUT.WAVE%,Audio.I.SPDIFOUT.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_HPOUT.WAVE%,Audio.I.HPOUT.WAVE
AddInterface=%KSCATEGORY_RENDER%,%KSNAME_HPOUT.WAVE%,Audio.I.HPOUT.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_RECIN.WAVE%,Audio.I.RECIN.WAVE
AddInterface=%KSCATEGORY_CAPTURE%,%KSNAME_RECIN.WAVE%,Audio.I.RECIN.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_MICIN.WAVE%,Audio.I.MICIN.WAVE
AddInterface=%KSCATEGORY_CAPTURE%,%KSNAME_MICIN.WAVE%,Audio.I.MICIN.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_LINEIN.WAVE%,Audio.I.LINEIN.WAVE
AddInterface=%KSCATEGORY_CAPTURE%,%KSNAME_LINEIN.WAVE%,Audio.I.LINEIN.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_SPDIFIN.WAVE%,Audio.I.SPDIFIN.WAVE
AddInterface=%KSCATEGORY_CAPTURE%,%KSNAME_SPDIFIN.WAVE%,Audio.I.SPDIFIN.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_GLOBAL.TOPO%,Audio.I.GLOBAL.TOPO
AddInterface=%KSCATEGORY_TOPOLOGY%,%KSNAME_GLOBAL.TOPO%,Audio.I.GLOBAL.TOPO

[ELO71AIR.NTamd64.Interfaces]
AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_SPEAKER.WAVE%,Audio.I.SPEAKER.WAVE
AddInterface=%KSCATEGORY_RENDER%,%KSNAME_SPEAKER.WAVE%,Audio.I.SPEAKER.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_SPDIFOUT.WAVE%,Audio.I.SPDIFOUT.WAVE
AddInterface=%KSCATEGORY_RENDER%,%KSNAME_SPDIFOUT.WAVE%,Audio.I.SPDIFOUT.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_HPOUT.WAVE%,Audio.I.HPOUT.WAVE
AddInterface=%KSCATEGORY_RENDER%,%KSNAME_HPOUT.WAVE%,Audio.I.HPOUT.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_RECIN.WAVE%,Audio.I.RECIN.WAVE
AddInterface=%KSCATEGORY_CAPTURE%,%KSNAME_RECIN.WAVE%,Audio.I.RECIN.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_MICIN.WAVE%,Audio.I.MICIN.WAVE
AddInterface=%KSCATEGORY_CAPTURE%,%KSNAME_MICIN.WAVE%,Audio.I.MICIN.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_LINEIN.WAVE%,Audio.I.LINEIN.WAVE
AddInterface=%KSCATEGORY_CAPTURE%,%KSNAME_LINEIN.WAVE%,Audio.I.LINEIN.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_SPDIFIN.WAVE%,Audio.I.SPDIFIN.WAVE
AddInterface=%KSCATEGORY_CAPTURE%,%KSNAME_SPDIFIN.WAVE%,Audio.I.SPDIFIN.WAVE

AddInterface=%KSCATEGORY_AUDIO%,%KSNAME_GLOBAL.TOPO%,Audio.I.GLOBAL.TOPO
AddInterface=%KSCATEGORY_TOPOLOGY%,%KSNAME_GLOBAL.TOPO%,Audio.I.GLOBAL.TOPO

[Audio.I.SPEAKER.WAVE]
AddReg=ELO71AIR.I.SPEAKER.WAVE.AddReg

[Audio.I.SPDIFOUT.WAVE]
AddReg=ELO71AIR.I.SPDIFOUT.WAVE.AddReg

[Audio.I.HPOUT.WAVE]
AddReg=ELO71AIR.I.HPOUT.WAVE.AddReg

[Audio.I.RECIN.WAVE]
AddReg=ELO71AIR.I.RECIN.WAVE.AddReg

[Audio.I.MICIN.WAVE]
AddReg=ELO71AIR.I.MICIN.WAVE.AddReg

[Audio.I.LINEIN.WAVE]
AddReg=ELO71AIR.I.LINEIN.WAVE.AddReg

[Audio.I.SPDIFIN.WAVE]
AddReg=ELO71AIR.I.SPDIFIN.WAVE.AddReg

[Audio.I.GLOBAL.TOPO]
AddReg=ELO71AIR.I.GLOBAL.TOPO.AddReg, SysFx.AddReg, ELO71AIR.EPProperties.AddReg

;---------------------------------------------------------------
;                A d d R e g
;---------------------------------------------------------------
[ELO71AIR.AddReg]
HKR,,Driver,,ELO71AIR.sys
HKR,,AssociatedFilters,,"wdmaud,redbook"
HKR,Drivers,SubClasses,,"wave,midi,mixer"
HKR,Drivers\wave\wdmaud.drv, Driver,,wdmaud.drv
HKR,Drivers\midi\wdmaud.drv, Driver,,wdmaud.drv
HKR,Drivers\mixer\wdmaud.drv,Driver,,wdmaud.drv
HKR,Drivers\wave\wdmaud.drv,Description,,%ELO71AIR.Audio.DeviceDesc%
HKR,Drivers\midi\wdmaud.drv,Description,,%ELO71AIR.Audio.DeviceDesc%
HKR,Drivers\mixer\wdmaud.drv,Description,,%ELO71AIR.Audio.DeviceDesc%

[ELO71AIR_NAMES.AddReg]
HKLM,%MediaCategories%\%ELO71AIRGUID.SpdifOut%,Name,,%ELO71AIRNode.SpdifOut%
HKLM,%MediaCategories%\%ELO71AIRGUID.SpdifOut%,Display,1,00,00,00,00
HKLM,%MediaCategories%\%ELO71AIRGUID.SpdifIn%,Name,,%ELO71AIRNode.SpdifIn%
HKLM,%MediaCategories%\%ELO71AIRGUID.SpdifIn%,Display,1,00,00,00,00

HKLM,%MediaCategories%\%HDAGuidStereoMixPin%,Name,,%HDAStereoMixPinName%
HKLM,%MediaCategories%\%HDAGuidStereoMixPin%,Display,1,00,00,00,00
HKLM,%MediaCategories%\%HDAGuidAuxInPin%,Name,,%HDAAuxInPinName%
HKLM,%MediaCategories%\%HDAGuidAuxInPin%,Display,1,00,00,00,00

HKLM,%MediaCategories%\%ELO71AIRGUID.XearSurHP%,Name,,%ELO71AIRNode.XearSurHP%
HKLM,%MediaCategories%\%ELO71AIRGUID.XearSurHP%,Display,1,00,00,00,00


[ELO71AIR.I.SPEAKER.WAVE.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ELO71AIR.SPEAKER.WAVE.szPname%

[ELO71AIR.I.SPDIFOUT.WAVE.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ELO71AIR.SPDIFOUT.WAVE.szPname%

[ELO71AIR.I.HPOUT.WAVE.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ELO71AIR.HPOUT.WAVE.szPname%

[ELO71AIR.I.RECIN.WAVE.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ELO71AIR.RECIN.WAVE.szPname%

[ELO71AIR.I.MICIN.WAVE.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ELO71AIR.MICIN.WAVE.szPname%

[ELO71AIR.I.LINEIN.WAVE.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ELO71AIR.LINEIN.WAVE.szPname%

[ELO71AIR.I.SPDIFIN.WAVE.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ELO71AIR.SPDIFIN.WAVE.szPname%

[ELO71AIR.I.GLOBAL.TOPO.AddReg]
HKR,,CLSID,,%Proxy.CLSID%
HKR,,FriendlyName,,%ELO71AIR.GLOBAL.TOPO.szPname%

[ELO71AIR.EPProperties.AddReg]
HKR,"EP\\0",%PKEY_AudioEndpoint_Association%,,%KSNODETYPE_ANY%
HKR,"EP\\0",%PKEY_AudioEndpoint_Supports_EventDriven_Mode%,0x00010001,0x1

[SysFx.AddReg]
HKR,"FX\\0",%PKEY_ItemNameDisplay%,,%SYSFX_FriendlyName%
HKR,"FX\\0",%PKEY_FX_UiClsid%,,%SYSFX_UI_CLSID%
HKR,"FX\\0",%PKEY_FX_PreMixClsid%,,%SYSFX_PREMIX_CLSID%
HKR,"FX\\0",%PKEY_FX_PostMixClsid%,,%SYSFX_POSTMIX_CLSID%
HKR,"FX\\0",%PKEY_FX_Association%,,%KSNODETYPE_SPEAKER%

HKR,"FX\\1",%PKEY_ItemNameDisplay%,,%SYSFX_FriendlyName%
HKR,"FX\\1",%PKEY_FX_UiClsid%,,%SYSFX_UI_CLSID%
HKR,"FX\\1",%PKEY_FX_PreMixClsid%,,%SYSFX_PREMIX_CLSID%
HKR,"FX\\1",%PKEY_FX_PostMixClsid%,,%SYSFX_POSTMIX_CLSID%
HKR,"FX\\1",%PKEY_FX_Association%,,%KSNODETYPE_HEADPHONES%

HKR,"FX\\2",%PKEY_ItemNameDisplay%,,%SYSFX_FriendlyName%
HKR,"FX\\2",%PKEY_FX_UiClsid%,,%SYSFX_UI_CLSID%
HKR,"FX\\2",%PKEY_FX_PreMixClsid%,,%SYSFX_PREMIX_CLSID%
HKR,"FX\\2",%PKEY_FX_PostMixClsid%,,%SYSFX_POSTMIX_CLSID%
HKR,"FX\\2",%PKEY_FX_Association%,,%KSNODETYPE_SPDIF_INTERFACE%

HKR,"FX\\3",%PKEY_ItemNameDisplay%,,%SYSFX_FriendlyName%
HKR,"FX\\3",%PKEY_FX_UiClsid%,,%SYSFX_UI_CLSID%
HKR,"FX\\3",%PKEY_FX_PreMixClsid%,,%SYSFX_PREMIX_CLSID%
HKR,"FX\\3",%PKEY_FX_Association%,,%KSNODETYPE_MICROPHONE%

HKR,"FX\\4",%PKEY_ItemNameDisplay%,,%SYSFX_FriendlyName%
HKR,"FX\\4",%PKEY_FX_UiClsid%,,%SYSFX_UI_CLSID%
HKR,"FX\\4",%PKEY_FX_PreMixClsid%,,%SYSFX_PREMIX_CLSID%
HKR,"FX\\4",%PKEY_FX_Association%,,%KSNODETYPE_DESKTOP_MICROPHONE%

[SfxFx.AddReg]
HKCR,CLSID\%SYSFX_POSTMIX_CLSID%,,,"CMEffect Class (Global)"
HKCR,CLSID\%SYSFX_POSTMIX_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\CMEFFECTAPO_ELO71AIR.dll
HKCR,CLSID\%SYSFX_POSTMIX_CLSID%\InProcServer32,ThreadingModel,,"Both"

HKCR,CLSID\%SYSFX_PREMIX_CLSID%,,,"CMEffect Class (Local)"
