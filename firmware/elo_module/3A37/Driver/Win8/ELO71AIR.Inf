[ELO71AIR.DelReg]
HKR,Settings

;---------------------------------------------------------------
;                S e r v i c e s  
;---------------------------------------------------------------

[ELO71AIR.Services]
AddService=ELO71AIR, 0x00000002, ELO71AIR.ServiceInstall

[ELO71AIR.NTamd64.Services]
AddService=ELO71AIR, 0x00000002, ELO71AIR.ServiceInstall

[ELO71AIR.ServiceInstall]
DisplayName=%ELO71AIR.SvcDesc%
ServiceType=%SERVICE_KERNEL_DRIVER%
StartType=%SERVICE_DEMAND_START%
ErrorControl=%SERVICE_ERROR_NORMAL%
ServiceBinary=%12%\ELO71AIR.sys

